#!/bin/bash
#SBATCH --job-name=ollama_cpu
#SBATCH --output=ollama_cpu.%j.out
#SBATCH --error=ollama_cpu.%j.err
#SBATCH --time=01:00:00
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --mem=30GB

module purge
module load ollama/0.15

# ~1 minute runtime
# Run Ollama server
ollama serve &
sleep 10
ollama pull gemma3:1b
ollama run gemma3:1b "What is geometry?"
