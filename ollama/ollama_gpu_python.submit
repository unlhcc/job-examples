#!/bin/bash
#SBATCH --job-name=ollama_gpu
#SBATCH --output=ollama_gpu.%j.out
#SBATCH --error=ollama_gpu.%j.err
#SBATCH --time=01:00:00
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --partition=gpu
#SBATCH --gres=gpu:1
#SBATCH --mem=10GB

module purge
module load ollama-gpu/0.15

# ~1 minute runtime
# Run Ollama server
ollama serve &
sleep 10

# download model
# ollama pull llama3

# run query
python ${PWD}/ollama-python-example.py >> response.txt
