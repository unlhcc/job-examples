# Minimal LAMMPS GPU test
  
units       real
atom_style  atomic
boundary    p p p

# Small box with a few atoms
region      box block 0 10 0 10 0 10
create_box  1 box
lattice     fcc 1.0
create_atoms 1 box

mass        1 12.011

# Simple LJ pair style, GPU-accelerated
pair_style  lj/cut 2.5
pair_coeff  1 1 0.1 1.0

# Integrator
velocity    all create 300.0 12345
fix         1 all nve

# Thermo output
thermo      10
thermo_style custom step temp pe ke etotal

# Run very short simulation
timestep    1.0
run         100
