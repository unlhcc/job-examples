#!/bin/bash
#SBATCH --job-name=lammps_gpu_example
#SBATCH --ntasks=4
#SBATCH --mem-per-cpu=1G
#SBATCH --time=00:15:00
#SBATCH --error=lammps_gpu_example.%J.err
#SBATCH --output=lammps_gpu_example.%J.out
#SBATCH --partition=gpu
#SBATCH --gres=gpu:4

module purge
module load compiler/gcc/11 openmpi/4.1 lammps-gpu/27June2024
mpirun lmp -sf gpu -in in_adapt.lmp 
